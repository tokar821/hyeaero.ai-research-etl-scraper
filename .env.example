# ETL Pipeline Configuration
# Copy this file to .env and fill in your actual values

# Environment: dev, prod, or local (local enables dry-run mode)
ENVIRONMENT=local

# Dry-run mode (true/false). When true, no actual uploads to storage occur.
# Local environment defaults to true.
DRY_RUN=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Akamai Object Storage Configuration
AKAMAI_ACCESS_KEY=your_access_key_here
AKAMAI_SECRET_KEY=your_secret_key_here
AKAMAI_ENDPOINT=https://your-akamai-endpoint.com
AKAMAI_BUCKET_NAME=your-bucket-name
AKAMAI_REGION=us-east-1
